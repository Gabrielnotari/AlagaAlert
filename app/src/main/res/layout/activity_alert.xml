<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#C62828"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Voltar"
            android:textColor="#FFCCCC"
            android:textSize="12sp"
            android:id="@+id/tvBack"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️ Alerta de Clima"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tvCityHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Carregando..."
            android:textColor="#FFCCCC"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            >

            <!-- Grid de cards de clima -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                >

                <!-- Card Chuva -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="10dp"
                    xmlns:app="http://schemas.android.com/apk/res-auto">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌧️ Chuva (1h)" android:textSize="11sp" android:textColor="#888888"/>
                        <TextView android:id="@+id/tvRain" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="24sp" android:textStyle="bold" android:textColor="#1A1A1A" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="mm/h" android:textSize="11sp" android:textColor="#AAAAAA"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card Temperatura -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="10dp"
                    xmlns:app="http://schemas.android.com/apk/res-auto">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌡️ Temperatura" android:textSize="11sp" android:textColor="#888888"/>
                        <TextView android:id="@+id/tvTemp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="24sp" android:textStyle="bold" android:textColor="#1A1A1A" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="°C" android:textSize="11sp" android:textColor="#AAAAAA"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card Umidade -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="10dp"
                    xmlns:app="http://schemas.android.com/apk/res-auto">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💧 Umidade" android:textSize="11sp" android:textColor="#888888"/>
                        <TextView android:id="@+id/tvHumidity" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="24sp" android:textStyle="bold" android:textColor="#1A1A1A" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="%" android:textSize="11sp" android:textColor="#AAAAAA"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card Descrição -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    app:cardCornerRadius="10dp"
                    xmlns:app="http://schemas.android.com/apk/res-auto">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌤️ Condição" android:textSize="11sp" android:textColor="#888888"/>
                        <TextView android:id="@+id/tvDescription" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="14sp" android:textStyle="bold" android:textColor="#1A1A1A" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </GridLayout>

            <!-- Card nível de risco -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:cardCornerRadius="10dp"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nível de risco atual"
                        android:textSize="12sp"
                        android:textColor="#888888"/>

                    <TextView
                        android:id="@+id/tvRiskLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calculando..."
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#C62828"
                        android:layout_marginTop="6dp"/>

                    <ProgressBar
                        android:id="@+id/progressRisk"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="#E53935"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card de orientação -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="#FFEBEE"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋 Orientações"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#B71C1C"/>

                    <TextView
                        android:id="@+id/tvOrientation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Carregando orientações..."
                        android:textSize="12sp"
                        android:textColor="#C62828"
                        android:lineSpacingExtra="4dp"
                        android:layout_marginTop="6dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>