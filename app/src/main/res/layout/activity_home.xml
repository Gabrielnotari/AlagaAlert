<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4FF">

    <!-- Header azul -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1565C0"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌊"
            android:textSize="40sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AlagaAlert"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monitoramento de enchentes"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvCityName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍 Carregando localização..."
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="10dp"
            android:background="#33FFFFFF"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"/>

    </LinearLayout>

    <!-- Card de alerta -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardAlert"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="10dp"
        app:cardBackgroundColor="#FFF3E0"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/tvAlertTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠️ Verificando alertas..."
                android:textColor="#E65100"
                android:textStyle="bold"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tvAlertMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Aguarde enquanto carregamos os dados de chuva."
                android:textColor="#BF360C"
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Botões de navegação -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        >

        <Button
            android:id="@+id/btnMap"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🗺️  Ver mapa de riscos"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/btnAlert"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🌧️  Consultar clima atual"
            android:backgroundTint="#0277BD"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/btnReport"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="📝  Reportar alagamento"
            android:backgroundTint="#FFFFFF"
            android:textColor="#1565C0"
            android:textSize="14sp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

</LinearLayout>